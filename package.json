{
  "name": "sizzy-landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx}\" --cache",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typewatch": "tsc --noEmit --watch",
    "reinstall": "rm -rf node_modules && rm -rf dist && bun install",
    "generate:og": "npx tsx scripts/generate-og-image.ts",
    "generate:favicons": "npx tsx scripts/generate-favicons.ts"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.8.2",
    "@radix-ui/react-alert-dialog": "^1.1.10",
    "@radix-ui/react-avatar": "^1.1.3",
